Options -MultiViews
RewriteEngine On

RewriteRule ^privacy-policy-2/?$ /privacy-policy/ [R=301,L]
RewriteRule ^hello-world/?$ / [R=301,L]
RewriteRule ^hello-world-2/?$ / [R=301,L]
RewriteRule ^category/uncategorized/?$ / [R=301,L]

RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^ / [R=301,L]
